# ============================================
# Google Maps Business Leads Scraper
# Environment Configuration
# ============================================

# --- Search Configuration ---
SEARCH_QUERY="restaurants in New York"
MAX_RESULTS=100

# --- Browser Settings ---
HEADLESS=true
SLOW_MO=50
BROWSER_TIMEOUT=60000

# --- Anti-Detection ---
USE_STEALTH=true
RANDOM_DELAY_MIN=1.5
RANDOM_DELAY_MAX=4.0

# --- Export Settings ---
EXPORT_FORMAT=csv
# Options: csv, xlsx, json
OUTPUT_DIR=output

# --- Logging ---
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR

# --- Proxy (Optional) ---
# PROXY_SERVER=http://user:pass@proxy.example.com:8080
